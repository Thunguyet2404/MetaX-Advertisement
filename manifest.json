{
  "manifest_version": 3,
  "name": "MetaX - Ads Checker",
  "version": "1.1.0",
  "description": "Check Meta/Facebook advertising accounts - Status, Limit, Balance, Spending",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://graph.facebook.com/*",
    "https://open.er-api.com/*",
    "https://business.facebook.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}